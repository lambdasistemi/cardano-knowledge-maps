  cardano:commentBy "Nimuë Lady of the Lake Pool (drep1y...6xdgl4)" ;
  cardano:commentPostedOn "2026-04-20T09:24:00Z"^^xsd:dateTime ;
  dcterms:description "This proposal only targets the UK, Germany and Switzerland?" ;
