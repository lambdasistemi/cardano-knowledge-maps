@prefix cardano: <https://lambdasistemi.github.io/cardano-knowledge-maps/vocab/cardano#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf:    <http://xmlns.com/foaf/0.1/> .
@prefix org:     <http://www.w3.org/ns/org#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix time:    <http://www.w3.org/2006/time#> .

# -- Bridge prefixes (graph-browser vocabulary) --------------------------------
@prefix gb:      <https://lambdasistemi.github.io/graph-browser/vocab/terms#> .
@prefix gbkind:  <https://lambdasistemi.github.io/graph-browser/vocab/kinds#> .
@prefix gbedge:  <https://lambdasistemi.github.io/graph-browser/vocab/edges#> .
@prefix n:       <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf/node/> .

# ==============================================================================
# Ontology header
# ==============================================================================

<https://lambdasistemi.github.io/cardano-knowledge-maps/vocab/cardano> a owl:Ontology ;
  rdfs:label "Cardano Domain Ontology" ;
  dcterms:description "Cardano blockchain concepts grounded in standard W3C vocabularies (PROV-O, ORG, SKOS, OWL-Time, FOAF, Dublin Core). Designed for interoperability: the same triples can be queried by graph-browser, Protege, Oxigraph, or any SPARQL endpoint." ;
  owl:versionInfo "0.1.0" ;
  owl:imports
    <http://www.w3.org/ns/prov-o#> ,
    <http://www.w3.org/ns/org#> ,
    <http://xmlns.com/foaf/0.1/> .

# ==============================================================================
# SKOS Concept Scheme — the Cardano governance taxonomy
# ==============================================================================

cardano:CardanoGovernanceScheme a skos:ConceptScheme ;
  rdfs:label "Cardano Governance" ;
  dcterms:description "Top-level concept scheme for CIP-1694 on-chain governance." .

cardano:CardanoSmartContractScheme a skos:ConceptScheme ;
  rdfs:label "Cardano Smart Contracts" ;
  dcterms:description "Plutus platform, languages, EUTxO model, and tooling." .

# ==============================================================================
# Classes — Governance domain
# ==============================================================================

# -- Actors --------------------------------------------------------------------

cardano:GovernanceActor a owl:Class ;
  rdfs:label "Governance Actor" ;
  rdfs:subClassOf foaf:Agent ;
  dcterms:description "An entity that participates in Cardano on-chain governance." .

cardano:DRep a owl:Class ;
  rdfs:label "Delegated Representative" ;
  rdfs:subClassOf cardano:GovernanceActor , org:Role ;
  dcterms:description "A registered delegate who votes on governance actions on behalf of ada holders." .

cardano:SPO a owl:Class ;
  rdfs:label "Stake Pool Operator" ;
  rdfs:subClassOf cardano:GovernanceActor , org:Role ;
  dcterms:description "An operator of a Cardano stake pool who votes on hard forks and security-relevant parameter changes." .

cardano:ConstitutionalCommittee a owl:Class ;
  rdfs:label "Constitutional Committee" ;
  rdfs:subClassOf cardano:GovernanceActor , org:FormalOrganization ;
  dcterms:description "A body that evaluates governance actions for constitutional compliance." .

cardano:AdaHolder a owl:Class ;
  rdfs:label "Ada Holder" ;
  rdfs:subClassOf cardano:GovernanceActor ;
  dcterms:description "A holder of ada who can delegate voting power, delegate stake, submit governance actions, and register as a DRep." .

cardano:GovernanceOrganization a owl:Class ;
  rdfs:label "Governance Organization" ;
  rdfs:subClassOf cardano:GovernanceActor , org:Organization ;
  dcterms:description "An off-chain organization that supports governance (e.g. Intersect, Cardano Foundation)." .

# -- Governance actions --------------------------------------------------------

cardano:GovernanceAction a owl:Class ;
  rdfs:label "Governance Action" ;
  rdfs:subClassOf prov:Activity ;
  dcterms:description "An on-chain proposal submitted by an ada holder that undergoes voting, ratification, and enactment." .

cardano:GovernanceActionType a owl:Class ;
  rdfs:label "Governance Action Type" ;
  rdfs:subClassOf skos:Concept ;
  skos:inScheme cardano:CardanoGovernanceScheme ;
  dcterms:description "One of the seven categories of governance action defined by CIP-1694." .

cardano:MotionOfNoConfidence a owl:Class ;
  rdfs:label "Motion of No-Confidence" ;
  rdfs:subClassOf cardano:GovernanceActionType .

cardano:UpdateCommittee a owl:Class ;
  rdfs:label "Update Committee / Threshold" ;
  rdfs:subClassOf cardano:GovernanceActionType .

cardano:NewConstitution a owl:Class ;
  rdfs:label "New Constitution / Guardrails Script" ;
  rdfs:subClassOf cardano:GovernanceActionType .

cardano:HardForkInitiation a owl:Class ;
  rdfs:label "Hard Fork Initiation" ;
  rdfs:subClassOf cardano:GovernanceActionType .

cardano:ProtocolParameterChange a owl:Class ;
  rdfs:label "Protocol Parameter Changes" ;
  rdfs:subClassOf cardano:GovernanceActionType .

cardano:TreasuryWithdrawal a owl:Class ;
  rdfs:label "Treasury Withdrawal" ;
  rdfs:subClassOf cardano:GovernanceActionType .

cardano:InfoAction a owl:Class ;
  rdfs:label "Info Action" ;
  rdfs:subClassOf cardano:GovernanceActionType .

# -- Governance processes ------------------------------------------------------

cardano:GovernanceProcess a owl:Class ;
  rdfs:label "Governance Process" ;
  rdfs:subClassOf prov:Activity ;
  dcterms:description "A stage in the governance action lifecycle." .

cardano:VotingProcess a owl:Class ;
  rdfs:label "Voting" ;
  rdfs:subClassOf cardano:GovernanceProcess .

cardano:RatificationProcess a owl:Class ;
  rdfs:label "Ratification" ;
  rdfs:subClassOf cardano:GovernanceProcess .

cardano:EnactmentProcess a owl:Class ;
  rdfs:label "Enactment" ;
  rdfs:subClassOf cardano:GovernanceProcess .

cardano:BootstrapPhase a owl:Class ;
  rdfs:label "Bootstrap Phase" ;
  rdfs:subClassOf cardano:GovernanceProcess ;
  dcterms:description "Initial governance phase where DRep participation was not required. Ended with Plomin hard fork." .

cardano:TreasuryBudgeting a owl:Class ;
  rdfs:label "Treasury Budgeting Process" ;
  rdfs:subClassOf cardano:GovernanceProcess .

# -- Mechanisms ----------------------------------------------------------------

cardano:GovernanceMechanism a owl:Class ;
  rdfs:label "Governance Mechanism" ;
  dcterms:description "A rule or structure that governs how governance actions are evaluated, constrained, or ordered." .

cardano:VotingThreshold a owl:Class ;
  rdfs:label "Voting Threshold" ;
  rdfs:subClassOf cardano:GovernanceMechanism ;
  dcterms:description "A quorum or approval threshold required for ratification, specific to a governance body and action type." .

cardano:DepositMechanism a owl:Class ;
  rdfs:label "Deposit Mechanism" ;
  rdfs:subClassOf cardano:GovernanceMechanism .

cardano:ActionChaining a owl:Class ;
  rdfs:label "Action Chaining" ;
  rdfs:subClassOf cardano:GovernanceMechanism .

cardano:HotColdKeySystem a owl:Class ;
  rdfs:label "Hot/Cold Key System" ;
  rdfs:subClassOf cardano:GovernanceMechanism .

cardano:PredefinedDRep a owl:Class ;
  rdfs:label "Pre-defined DRep Option" ;
  rdfs:subClassOf cardano:GovernanceMechanism ;
  dcterms:description "A pre-defined delegation target (Abstain or No Confidence) that ada holders can delegate to." .

# -- Artifacts -----------------------------------------------------------------

cardano:GovernanceArtifact a owl:Class ;
  rdfs:label "Governance Artifact" ;
  rdfs:subClassOf foaf:Document , prov:Entity ;
  dcterms:description "A document or on-chain script that defines or constrains governance behavior." .

cardano:Constitution a owl:Class ;
  rdfs:label "Cardano Constitution" ;
  rdfs:subClassOf cardano:GovernanceArtifact .

cardano:GuardrailsScript a owl:Class ;
  rdfs:label "Guardrails Script" ;
  rdfs:subClassOf cardano:GovernanceArtifact ;
  dcterms:description "On-chain Plutus script that encodes constitutional constraints on parameter changes and treasury withdrawals." .

# -- Protocol parameters -------------------------------------------------------

cardano:ProtocolParameter a owl:Class ;
  rdfs:label "Protocol Parameter" ;
  rdfs:subClassOf skos:Concept ;
  skos:inScheme cardano:CardanoGovernanceScheme ;
  dcterms:description "A configurable parameter of the Cardano protocol." .

cardano:ParameterGroup a owl:Class ;
  rdfs:label "Parameter Group" ;
  rdfs:subClassOf skos:Collection ;
  dcterms:description "A grouping of protocol parameters (Network, Economic, Technical, Governance)." .

cardano:SecurityRelevantParameter a owl:Class ;
  rdfs:label "Security-Relevant Parameter" ;
  rdfs:subClassOf cardano:GovernanceMechanism ;
  dcterms:description "Parameters whose changes require SPO approval in addition to DRep approval." .

# -- Standards -----------------------------------------------------------------

cardano:CIP a owl:Class ;
  rdfs:label "Cardano Improvement Proposal" ;
  rdfs:subClassOf foaf:Document , skos:Concept ;
  dcterms:description "A formal specification document in the CIP process." .

# -- Ledger eras ---------------------------------------------------------------

cardano:LedgerEra a owl:Class ;
  rdfs:label "Ledger Era" ;
  rdfs:subClassOf time:ProperInterval ;
  dcterms:description "A major version of the Cardano ledger rules, bounded by hard forks." .

# ==============================================================================
# Classes — Smart contract domain
# ==============================================================================

cardano:SmartContractConcept a owl:Class ;
  rdfs:label "Smart Contract Concept" ;
  rdfs:subClassOf skos:Concept ;
  skos:inScheme cardano:CardanoSmartContractScheme .

cardano:SmartContractLanguage a owl:Class ;
  rdfs:label "Smart Contract Language" ;
  rdfs:subClassOf cardano:SmartContractConcept ;
  dcterms:description "A programming language that targets Plutus Core for on-chain execution." .

cardano:SmartContractRuntime a owl:Class ;
  rdfs:label "Smart Contract Runtime" ;
  rdfs:subClassOf cardano:SmartContractConcept ;
  dcterms:description "An execution environment for Cardano smart contracts." .

cardano:SmartContractPattern a owl:Class ;
  rdfs:label "Smart Contract Pattern" ;
  rdfs:subClassOf cardano:SmartContractConcept ;
  dcterms:description "A design pattern for building Cardano smart contracts." .

cardano:TransactionComponent a owl:Class ;
  rdfs:label "Transaction Component" ;
  rdfs:subClassOf cardano:SmartContractConcept ;
  dcterms:description "A component of a Cardano transaction (datum, redeemer, script context, etc.)." .

cardano:DApp a owl:Class ;
  rdfs:label "Decentralized Application" ;
  rdfs:subClassOf prov:SoftwareAgent ;
  dcterms:description "A decentralized application built on the Cardano platform." .

cardano:DeveloperTool a owl:Class ;
  rdfs:label "Developer Tool" ;
  rdfs:subClassOf prov:SoftwareAgent ;
  dcterms:description "A tool or SDK for building on Cardano." .

cardano:VasilFeature a owl:Class ;
  rdfs:label "Vasil-Era Feature" ;
  rdfs:subClassOf cardano:GovernanceMechanism ;
  dcterms:description "A ledger feature introduced in the Vasil/Babbage hard fork." .

# -- Layer 2 / Scaling ---------------------------------------------------------

cardano:L2Protocol a owl:Class ;
  rdfs:label "Layer 2 Protocol" ;
  rdfs:subClassOf cardano:DApp ;
  dcterms:description "A scaling protocol that processes transactions off-chain while inheriting L1 security." .

cardano:L2Component a owl:Class ;
  rdfs:label "Layer 2 Component" ;
  rdfs:subClassOf cardano:SmartContractConcept ;
  dcterms:description "A component of a Layer 2 scaling protocol." .

cardano:L2Lifecycle a owl:Class ;
  rdfs:label "Layer 2 Lifecycle Phase" ;
  rdfs:subClassOf cardano:SmartContractConcept ;
  dcterms:description "A phase in the lifecycle of a Layer 2 head or channel." .

# ==============================================================================
# Classes — Budget proposal domain
#
# Models the structural requirements every Cardano Budget 2026 proposal must
# satisfy: proposer, requested amount, duration, administrator, strategic
# pillar alignment, supported KPIs, work packages with milestones and budget
# breakdowns, repayment terms, and community comments.
# ==============================================================================

cardano:BudgetProcess a owl:Class ;
  rdfs:label "Cardano Budget Process" ;
  rdfs:subClassOf cardano:TreasuryBudgeting ;
  dcterms:description "A multi-cycle treasury budgeting process running under CIP-1694 governance — for example Cardano Budget 2026. Aggregates submitted proposals, defines submission/voting windows, and gates Treasury Withdrawal actions." .

cardano:BudgetProposal a owl:Class ;
  rdfs:label "Budget Proposal" ;
  rdfs:subClassOf cardano:GovernanceArtifact ;
  dcterms:description "A proposal submitted to a BudgetProcess. Carries an applicant identity, a requested ADA amount, an estimated duration, an administrator, alignment with one or more Cardano 2030 strategic pillars, the KPIs it claims to support, a structured set of work packages, and treasury repayment terms. Approved proposals are enacted via Treasury Withdrawal governance actions." .

cardano:Proposer a owl:Class ;
  rdfs:label "Proposer" ;
  rdfs:subClassOf org:Organization ;
  dcterms:description "The applicant submitting a Budget Proposal. May be a Company or an Individual; recorded via cardano:applicantType on the proposal." .

cardano:WorkPackage a owl:Class ;
  rdfs:label "Work Package" ;
  dcterms:description "A discrete delivery unit within a Budget Proposal with its own budget, cost categories, milestones, and success criteria. Approved budget for the next work package is typically gated by demonstrated delivery of the previous one." .

cardano:WorkPackageMilestone a owl:Class ;
  rdfs:label "Work Package Milestone" ;
  dcterms:description "A milestone inside a Work Package, marked by a month offset (M1, M3, M15, ...) from project start. Distinct from cardano:GovernanceAction milestones." .

cardano:CostCategory a owl:Class ;
  rdfs:label "Cost Category" ;
  dcterms:description "A budget category used by Intersect's Budget process: Labor, Infrastructure, Security & Audits, Legal & Compliance, Engagement & Ecosystem support, Development." .

cardano:BudgetLineItem a owl:Class ;
  rdfs:label "Budget Line Item" ;
  dcterms:description "One row in a Work Package's budget breakdown: an ADA amount in a specific Cost Category, optionally attributed to a partner organisation or named role." .

cardano:StrategicPillar a owl:Class ;
  rdfs:label "Cardano 2030 Strategic Pillar" ;
  dcterms:description "One of the five strategic pillars of the Cardano 2030 Strategy Framework. A Budget Proposal declares which pillars it advances and explains the rationale." .

cardano:StrategyKPI a owl:Class ;
  rdfs:label "Cardano 2030 Strategy KPI" ;
  dcterms:description "A measurable target defined by the Cardano 2030 Strategy Framework — e.g. Total Value Locked, Monthly Transactions, Annual Protocol Revenue. Proposals declare which KPIs they support and may propose new ones." .

cardano:RepaymentClause a owl:Class ;
  rdfs:label "Treasury Repayment Clause" ;
  dcterms:description "A commitment a proposal makes about returning value to the Cardano Treasury — for example a percentage of future protocol revenue, a buffer surplus return on FX-rate movement, or unused budget at project close." .

cardano:ProposalComment a owl:Class ;
  rdfs:label "Budget Proposal Comment" ;
  dcterms:description "A community comment posted on a Budget Proposal's discussion thread. Carries author stake or DRep ID and a timestamp." .

# ==============================================================================
# Properties — Governance
# ==============================================================================

cardano:votesOn a owl:ObjectProperty ;
  rdfs:label "votes on" ;
  rdfs:domain cardano:GovernanceActor ;
  rdfs:range cardano:GovernanceActionType ;
  rdfs:subPropertyOf prov:influenced ;
  dcterms:description "Indicates which governance action types an actor body votes on." .

cardano:evaluatesAndVotesOn a owl:ObjectProperty ;
  rdfs:label "evaluates and votes on" ;
  rdfs:subPropertyOf cardano:votesOn ;
  rdfs:domain cardano:ConstitutionalCommittee ;
  dcterms:description "CC evaluates actions for constitutionality before casting a vote." .

cardano:delegatesVotingPowerTo a owl:ObjectProperty ;
  rdfs:label "delegates voting power to" ;
  rdfs:domain cardano:AdaHolder ;
  rdfs:range cardano:GovernanceActor ;
  dcterms:description "Ada holder delegates governance voting power to a DRep or pre-defined option." .

cardano:delegatesStakeTo a owl:ObjectProperty ;
  rdfs:label "delegates stake to" ;
  rdfs:domain cardano:AdaHolder ;
  rdfs:range cardano:SPO ;
  dcterms:description "Ada holder delegates stake to a stake pool for block production rewards." .

cardano:submits a owl:ObjectProperty ;
  rdfs:label "submits" ;
  rdfs:domain cardano:GovernanceActor ;
  rdfs:range cardano:GovernanceAction ;
  rdfs:subPropertyOf prov:wasStartedBy ;
  dcterms:description "Actor submits a governance action on-chain." .

cardano:constrains a owl:ObjectProperty ;
  rdfs:label "constrains" ;
  rdfs:domain [ a owl:Class ; owl:unionOf ( cardano:GovernanceArtifact cardano:GovernanceMechanism ) ] ;
  rdfs:range cardano:GovernanceAction ;
  dcterms:description "A rule or artifact that limits what a governance action can do." .

cardano:evaluatesAgainst a owl:ObjectProperty ;
  rdfs:label "evaluates actions against" ;
  rdfs:domain cardano:ConstitutionalCommittee ;
  rdfs:range cardano:Constitution ;
  dcterms:description "CC evaluates governance actions for compliance with the Constitution." .

cardano:leadsTo a owl:ObjectProperty ;
  rdfs:label "leads to" ;
  rdfs:domain cardano:GovernanceProcess ;
  rdfs:range cardano:GovernanceProcess ;
  dcterms:description "Governance lifecycle sequencing (voting leads to ratification leads to enactment)." .

cardano:requires a owl:ObjectProperty ;
  rdfs:label "requires" ;
  rdfs:range cardano:GovernanceMechanism ;
  dcterms:description "A concept or action that depends on a governance mechanism (e.g. deposit)." .

cardano:subjectTo a owl:ObjectProperty ;
  rdfs:label "subject to" ;
  rdfs:range cardano:VotingThreshold ;
  dcterms:description "A governance body whose votes are governed by a threshold." .

cardano:canDelegateTo a owl:ObjectProperty ;
  rdfs:label "can delegate to" ;
  rdfs:domain cardano:AdaHolder ;
  rdfs:range cardano:PredefinedDRep ;
  dcterms:description "Ada holder can delegate to a pre-defined DRep option." .

cardano:canRegisterAs a owl:ObjectProperty ;
  rdfs:label "can register as" ;
  rdfs:domain cardano:AdaHolder ;
  rdfs:range cardano:DRep ;
  dcterms:description "Any ada holder can register as a DRep." .

cardano:changesMembershipOf a owl:ObjectProperty ;
  rdfs:label "changes membership of" ;
  rdfs:domain cardano:UpdateCommittee ;
  rdfs:range cardano:ConstitutionalCommittee .

cardano:putsIntoNoConfidenceState a owl:ObjectProperty ;
  rdfs:label "puts into no-confidence state" ;
  rdfs:domain cardano:MotionOfNoConfidence ;
  rdfs:range cardano:ConstitutionalCommittee .

cardano:codifiedIn a owl:ObjectProperty ;
  rdfs:label "codified in" ;
  rdfs:domain cardano:Constitution ;
  rdfs:range cardano:GuardrailsScript ;
  dcterms:description "Constitutional constraints encoded as on-chain Plutus script." .

cardano:modifiesVotingFor a owl:ObjectProperty ;
  rdfs:label "modifies voting for" ;
  rdfs:domain cardano:GovernanceMechanism ;
  rdfs:range cardano:GovernanceActionType ;
  dcterms:description "A threshold exception that modifies voting requirements for specific action types." .

# -- Protocol parameters -------------------------------------------------------

cardano:belongsToGroup a owl:ObjectProperty ;
  rdfs:label "belongs to" ;
  rdfs:domain cardano:ProtocolParameter ;
  rdfs:range cardano:ParameterGroup .

cardano:canChange a owl:ObjectProperty ;
  rdfs:label "can change" ;
  rdfs:domain cardano:GovernanceActionType ;
  rdfs:range cardano:ParameterGroup ;
  dcterms:description "Protocol Parameter Changes action type can modify parameters in this group." .

cardano:affects a owl:ObjectProperty ;
  rdfs:label "affects" ;
  rdfs:range cardano:ProtocolParameter .

# ==============================================================================
# Properties — Smart contracts
# ==============================================================================

cardano:compilesTo a owl:ObjectProperty ;
  rdfs:label "compiles to" ;
  rdfs:domain cardano:SmartContractLanguage ;
  rdfs:range cardano:SmartContractRuntime ;
  dcterms:description "Language compilation target (e.g. Aiken compiles to UPLC via Plutus Core)." .

cardano:evaluatedBy a owl:ObjectProperty ;
  rdfs:label "evaluated by" ;
  rdfs:range cardano:SmartContractRuntime .

cardano:pricedBy a owl:ObjectProperty ;
  rdfs:label "priced by" ;
  rdfs:range cardano:ProtocolParameter ;
  dcterms:description "Execution cost determined by a protocol parameter (cost model)." .

cardano:builtOn a owl:ObjectProperty ;
  rdfs:label "built on" ;
  rdfs:domain cardano:DApp ;
  dcterms:description "A dApp built on a smart contract platform." .

cardano:writtenIn a owl:ObjectProperty ;
  rdfs:label "written in" ;
  rdfs:domain cardano:DApp ;
  rdfs:range cardano:SmartContractLanguage .

cardano:buildsTransactionsFor a owl:ObjectProperty ;
  rdfs:label "builds transactions for" ;
  rdfs:domain cardano:DeveloperTool ;
  dcterms:description "Tool constructs off-chain transactions for a platform." .

cardano:indexes a owl:ObjectProperty ;
  rdfs:label "indexes" ;
  rdfs:domain cardano:DeveloperTool ;
  dcterms:description "Tool indexes chain data." .

# -- Standards / general -------------------------------------------------------

cardano:specifies a owl:ObjectProperty ;
  rdfs:label "specifies" ;
  rdfs:domain cardano:CIP ;
  dcterms:description "A CIP that defines or specifies a concept." .

cardano:implementedIn a owl:ObjectProperty ;
  rdfs:label "implemented in" ;
  rdfs:range cardano:LedgerEra .

cardano:enables a owl:ObjectProperty ;
  rdfs:label "enables" ;
  dcterms:description "A tool or feature that enables a capability." .

cardano:facilitates a owl:ObjectProperty ;
  rdfs:label "facilitates" ;
  rdfs:domain cardano:GovernanceOrganization .

cardano:documents a owl:ObjectProperty ;
  rdfs:label "documents" ;
  rdfs:domain cardano:CIP ;
  dcterms:description "A CIP documenting a platform or protocol feature." .

cardano:succeeds a owl:ObjectProperty ;
  rdfs:label "succeeds" ;
  rdfs:domain cardano:CIP ;
  rdfs:range cardano:CIP ;
  dcterms:description "A CIP that supersedes or extends a previous CIP." .

cardano:profileFollows a owl:ObjectProperty ;
  rdfs:label "profile follows" ;
  rdfs:domain cardano:GovernanceActor ;
  rdfs:range cardano:CIP ;
  dcterms:description "An actor publishes profile metadata following a CIP standard." .

cardano:rendersProfilesFrom a owl:ObjectProperty ;
  rdfs:label "renders profiles from" ;
  rdfs:domain cardano:DeveloperTool ;
  rdfs:range cardano:CIP ;
  dcterms:description "A tool renders actor profile data structured according to a CIP." .

cardano:unifiesScriptTypesIn a owl:ObjectProperty ;
  rdfs:label "unifies script types in" ;
  rdfs:domain cardano:CIP ;
  rdfs:range cardano:SmartContractConcept ;
  dcterms:description "A CIP that unifies the script interface for a smart contract platform." .

cardano:addsBuiltInsTo a owl:ObjectProperty ;
  rdfs:label "adds built-ins to" ;
  rdfs:domain cardano:CIP ;
  rdfs:range cardano:SmartContractRuntime ;
  dcterms:description "A CIP that adds new built-in functions to a runtime." .

cardano:optimizes a owl:ObjectProperty ;
  rdfs:label "optimizes" ;
  rdfs:domain cardano:CIP ;
  rdfs:range cardano:SmartContractRuntime ;
  dcterms:description "A CIP that improves the performance of a runtime." .

cardano:registersMetadataFor a owl:ObjectProperty ;
  rdfs:label "registers metadata for" ;
  rdfs:domain cardano:CIP ;
  rdfs:range cardano:SmartContractConcept .

cardano:settlesOn a owl:ObjectProperty ;
  rdfs:label "settles on" ;
  rdfs:domain cardano:L2Protocol ;
  rdfs:range cardano:SmartContractConcept ;
  dcterms:description "An L2 protocol that settles state transitions on an L1 ledger." .

cardano:lifecyclePhaseOf a owl:ObjectProperty ;
  rdfs:label "lifecycle phase of" ;
  rdfs:domain cardano:L2Lifecycle ;
  rdfs:range cardano:L2Protocol ;
  dcterms:description "A lifecycle phase belonging to an L2 protocol." .

cardano:componentOf a owl:ObjectProperty ;
  rdfs:label "component of" ;
  rdfs:domain cardano:L2Component ;
  rdfs:range cardano:L2Protocol ;
  dcterms:description "A component belonging to an L2 protocol." .

cardano:maintainedBy a owl:ObjectProperty ;
  rdfs:label "maintained by" ;
  rdfs:range foaf:Agent ;
  dcterms:description "An entity that maintains a project or tool." .

# ==============================================================================
# Properties — Budget proposal domain
# ==============================================================================

cardano:partOfBudgetProcess a owl:ObjectProperty ;
  rdfs:label "part of budget process" ;
  rdfs:domain cardano:BudgetProposal ;
  rdfs:range cardano:BudgetProcess ;
  dcterms:description "Identifies which annual budget process a proposal was submitted to." .

cardano:proposedBy a owl:ObjectProperty ;
  rdfs:label "proposed by" ;
  rdfs:domain cardano:BudgetProposal ;
  rdfs:range cardano:Proposer ;
  dcterms:description "The applicant submitting the proposal." .

cardano:administeredBy a owl:ObjectProperty ;
  rdfs:label "administered by" ;
  rdfs:domain cardano:BudgetProposal ;
  rdfs:range org:Organization ;
  dcterms:description "The organisation responsible for milestone oversight, smart-contract disbursement, third-party reviews and reporting (e.g. Intersect)." .

cardano:alignsWithPillar a owl:ObjectProperty ;
  rdfs:label "aligns with strategic pillar" ;
  rdfs:domain cardano:BudgetProposal ;
  rdfs:range cardano:StrategicPillar ;
  dcterms:description "A Cardano 2030 Strategy Framework pillar the proposal claims to advance." .

cardano:supportsKPI a owl:ObjectProperty ;
  rdfs:label "supports KPI" ;
  rdfs:domain cardano:BudgetProposal ;
  rdfs:range cardano:StrategyKPI ;
  dcterms:description "An existing Cardano 2030 Strategy Framework KPI the proposal claims to contribute to." .

cardano:proposesNewKPI a owl:ObjectProperty ;
  rdfs:label "proposes new KPI" ;
  rdfs:domain cardano:BudgetProposal ;
  rdfs:range cardano:StrategyKPI ;
  dcterms:description "A novel KPI introduced by the proposal beyond the framework's defined set." .

cardano:hasWorkPackage a owl:ObjectProperty ;
  rdfs:label "has work package" ;
  rdfs:domain cardano:BudgetProposal ;
  rdfs:range cardano:WorkPackage ;
  dcterms:description "A work package belonging to the proposal." .

cardano:hasWorkPackageMilestone a owl:ObjectProperty ;
  rdfs:label "has milestone" ;
  rdfs:domain cardano:WorkPackage ;
  rdfs:range cardano:WorkPackageMilestone ;
  dcterms:description "A delivery milestone inside a work package." .

cardano:hasBudgetLineItem a owl:ObjectProperty ;
  rdfs:label "has budget line item" ;
  rdfs:domain cardano:WorkPackage ;
  rdfs:range cardano:BudgetLineItem ;
  dcterms:description "A line in the work package's budget breakdown." .

cardano:lineItemCategory a owl:ObjectProperty ;
  rdfs:label "line item category" ;
  rdfs:domain cardano:BudgetLineItem ;
  rdfs:range cardano:CostCategory ;
  dcterms:description "The cost category an individual budget line falls under." .

cardano:lineItemPerformedBy a owl:ObjectProperty ;
  rdfs:label "line item performed by" ;
  rdfs:domain cardano:BudgetLineItem ;
  rdfs:range foaf:Agent ;
  dcterms:description "The partner organisation or named role responsible for delivering this line item." .

cardano:hasRepaymentClause a owl:ObjectProperty ;
  rdfs:label "has repayment clause" ;
  rdfs:domain cardano:BudgetProposal ;
  rdfs:range cardano:RepaymentClause ;
  dcterms:description "A repayment commitment the proposal makes to the Cardano Treasury." .

cardano:repaysToTreasury a owl:ObjectProperty ;
  rdfs:label "repays to treasury" ;
  rdfs:domain cardano:RepaymentClause ;
  rdfs:range cardano:TreasuryBudgeting ;
  dcterms:description "The treasury process that receives repaid value." .

cardano:hasComment a owl:ObjectProperty ;
  rdfs:label "has comment" ;
  rdfs:domain cardano:BudgetProposal ;
  rdfs:range cardano:ProposalComment ;
  dcterms:description "A community comment on the proposal's discussion thread." .

# -- Datatype properties for budget proposals ----------------------------------

cardano:requestedAdaAmount a owl:DatatypeProperty ;
  rdfs:label "requested ADA amount" ;
  rdfs:domain cardano:BudgetProposal ;
  rdfs:range xsd:decimal ;
  dcterms:description "ADA amount requested from the treasury." .

cardano:requestedUsdAmount a owl:DatatypeProperty ;
  rdfs:label "requested USD equivalent" ;
  rdfs:domain cardano:BudgetProposal ;
  rdfs:range xsd:decimal ;
  dcterms:description "USD equivalent of the requested ADA amount, computed at the proposer-specified ADA/USD rate." .

cardano:adaUsdRate a owl:DatatypeProperty ;
  rdfs:label "ADA/USD conversion rate" ;
  rdfs:domain cardano:BudgetProposal ;
  rdfs:range xsd:decimal ;
  dcterms:description "Conversion rate (USD per 1 ADA) the proposer used to derive the USD equivalent." .

cardano:estimatedDurationMonths a owl:DatatypeProperty ;
  rdfs:label "estimated duration (months)" ;
  rdfs:domain cardano:BudgetProposal ;
  rdfs:range xsd:integer ;
  dcterms:description "Total project duration in months." .

cardano:submittedOn a owl:DatatypeProperty ;
  rdfs:label "submitted on" ;
  rdfs:domain cardano:BudgetProposal ;
  rdfs:range xsd:dateTime ;
  dcterms:description "Submission timestamp on the Hydra Voting site." .

cardano:proposalIdentifier a owl:DatatypeProperty ;
  rdfs:label "proposal identifier" ;
  rdfs:domain cardano:BudgetProposal ;
  rdfs:range xsd:string ;
  dcterms:description "Stable identifier on the Hydra Voting site." .

cardano:applicantType a owl:DatatypeProperty ;
  rdfs:label "applicant type" ;
  rdfs:domain cardano:BudgetProposal ;
  rdfs:range xsd:string ;
  dcterms:description "Whether the applicant is registered as a Company or as an Individual." .

cardano:proposalNature a owl:DatatypeProperty ;
  rdfs:label "proposal nature" ;
  rdfs:domain cardano:WorkPackage ;
  rdfs:range xsd:string ;
  dcterms:description "Whether the work package is Technical or Non-technical, per the application form." .

cardano:initiativeStatus a owl:DatatypeProperty ;
  rdfs:label "initiative status" ;
  rdfs:domain cardano:WorkPackage ;
  rdfs:range xsd:string ;
  dcterms:description "Whether the work is a 'New Initiative' or a 'Continuation of existing work', per the application form." .

cardano:wpAdaAmount a owl:DatatypeProperty ;
  rdfs:label "work package ADA amount" ;
  rdfs:domain cardano:WorkPackage ;
  rdfs:range xsd:decimal ;
  dcterms:description "Total ADA budget for a work package." .

cardano:lineItemAdaAmount a owl:DatatypeProperty ;
  rdfs:label "line item ADA amount" ;
  rdfs:domain cardano:BudgetLineItem ;
  rdfs:range xsd:decimal ;
  dcterms:description "ADA amount for a single budget line item." .

cardano:milestoneMonth a owl:DatatypeProperty ;
  rdfs:label "milestone month" ;
  rdfs:domain cardano:WorkPackageMilestone ;
  rdfs:range xsd:integer ;
  dcterms:description "Month offset (M1, M3, M15) from project start at which the milestone is due." .

cardano:kpiCurrentValue a owl:DatatypeProperty ;
  rdfs:label "KPI current value" ;
  rdfs:domain cardano:StrategyKPI ;
  rdfs:range xsd:string ;
  dcterms:description "Current measured value of the KPI, as cited in the proposal." .

cardano:kpiTargetValue a owl:DatatypeProperty ;
  rdfs:label "KPI target value" ;
  rdfs:domain cardano:StrategyKPI ;
  rdfs:range xsd:string ;
  dcterms:description "Target value the KPI is meant to reach (typically by 2030)." .

cardano:commentBy a owl:DatatypeProperty ;
  rdfs:label "comment by" ;
  rdfs:domain cardano:ProposalComment ;
  rdfs:range xsd:string ;
  dcterms:description "Display name or stake/DRep alias of the commenter." .

cardano:commentPostedOn a owl:DatatypeProperty ;
  rdfs:label "comment posted on" ;
  rdfs:domain cardano:ProposalComment ;
  rdfs:range xsd:dateTime ;
  dcterms:description "Timestamp at which the comment was posted." .

# ==============================================================================
# Alignment — bridge gbkind: classes to cardano: classes
# ==============================================================================

gbkind:actor         owl:equivalentClass  cardano:GovernanceActor .
gbkind:action-type   owl:equivalentClass  cardano:GovernanceActionType .
gbkind:process       owl:equivalentClass  cardano:GovernanceProcess .
gbkind:mechanism     owl:equivalentClass  cardano:GovernanceMechanism .
gbkind:artifact      owl:equivalentClass  cardano:GovernanceArtifact .
gbkind:concept       owl:equivalentClass  cardano:SmartContractConcept .
gbkind:param-group   owl:equivalentClass  cardano:ParameterGroup .
gbkind:parameter     owl:equivalentClass  cardano:ProtocolParameter .
gbkind:tool          owl:equivalentClass  cardano:DeveloperTool .
gbkind:language      owl:equivalentClass  cardano:SmartContractLanguage .
gbkind:protocol      owl:equivalentClass  cardano:DApp .
gbkind:runtime       owl:equivalentClass  cardano:SmartContractRuntime .
gbkind:standard      owl:equivalentClass  cardano:CIP .

# Note: owl:equivalentProperty mappings removed — instance TTLs use
# cardano: and standard predicates directly (see #35).

# ==============================================================================
# Instance typing — give existing nodes their cardano: types
# (additive: nodes keep gb:Node + gbkind:X, gain cardano:Y)
# ==============================================================================

# -- Governance actors ---------------------------------------------------------
n:ada-holder           a cardano:AdaHolder .
n:drep                 a cardano:DRep .
n:spo                  a cardano:SPO .
n:cc                   a cardano:ConstitutionalCommittee .
n:intersect            a cardano:GovernanceOrganization .
n:cardano-foundation   a cardano:GovernanceOrganization .

# -- Action types --------------------------------------------------------------
n:action-no-confidence    a cardano:MotionOfNoConfidence .
n:action-update-committee a cardano:UpdateCommittee .
n:action-new-constitution a cardano:NewConstitution .
n:action-hard-fork        a cardano:HardForkInitiation .
n:action-param-change     a cardano:ProtocolParameterChange .
n:action-treasury         a cardano:TreasuryWithdrawal .
n:action-info             a cardano:InfoAction .

# -- Processes -----------------------------------------------------------------
